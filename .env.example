# LLMod.AI (course-provided proxy — see Lecture 4 slide 31)
LLMOD_API_KEY=sk-...your-key-here...
LLMOD_BASE_URL=https://api.llmod.ai/v1

# Pinecone serverless
PINECONE_API_KEY=...your-key-here...

# Optional overrides (uncomment to use)
